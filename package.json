{
  "name": "syntek-solutions",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "verify-audit": "tsx scripts/verify-audit.ts",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:integration:repository": "node --conditions=react-server -r dotenv/config --import tsx tests/integration/contact.repository.test.ts",
    "test:integration:rpc": "node --conditions=react-server -r dotenv/config --import tsx tests/integration/contact.rpc.test.ts",
    "test:integration:service": "node --conditions=react-server -r dotenv/config --import tsx tests/integration/contact.service.test.ts",
    "test:integration": "npm run test:integration:repository && npm run test:integration:rpc && npm run test:integration:service",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.3",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-email/body": "^0.3.0",
    "@react-email/button": "^0.2.1",
    "@react-email/column": "^0.0.14",
    "@react-email/container": "^0.0.16",
    "@react-email/head": "^0.0.13",
    "@react-email/heading": "^0.0.16",
    "@react-email/hr": "^0.0.12",
    "@react-email/html": "^0.0.12",
    "@react-email/img": "^0.0.12",
    "@react-email/link": "^0.0.13",
    "@react-email/preview": "^0.0.14",
    "@react-email/row": "^0.0.13",
    "@react-email/section": "^0.0.17",
    "@react-email/text": "^0.1.6",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.20.0",
    "next": "15.5.19",
    "pg": "^8.21.0",
    "radix-ui": "^1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-email": "^6.6.3",
    "react-hook-form": "^7.78.0",
    "resend": "^6.13.0",
    "server-only": "^0.0.1",
    "svix": "^1.95.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "prisma": "^7.8.0",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
